# ============================================================
# Editorial Signal — variables d'environnement
# Copier ce fichier en .env et remplir les vraies valeurs.
# .env est ignoré par git (cf .gitignore).
# ============================================================

# --- MSN News ---
# La clé d'API publique embarquée dans assets.msn.com (déjà connue,
# la même que dans gnewsalyzer V2 / cron_msn_news.php).
MSN_API_KEY=0QfOX3Vn51YCzitbLaRkTTBadtWpgTN8NZLW0C1SEM
MSN_MARKET=fr-fr
MSN_LIMIT=100

# --- Google Trends via SerpAPI ---
# Crée une clé sur https://serpapi.com/dashboard
SERPAPI_KEY=
SERPAPI_GEO=FR

# --- Wikimedia ---
# User-Agent recommandé par Wikipedia : doit identifier le projet et
# fournir un contact. Format: "Nom/Version (URL; contact)"
WIKIMEDIA_USER_AGENT=EditorialSignal/0.1 (https://github.com/labisse/Newsroom; contact@example.com)
WIKIMEDIA_PROJECT=fr.wikipedia

# --- X Trends (scraping trends24.in) ---
# Pas d'auth — juste un User-Agent navigateur.
X_TRENDS_URL=https://trends24.in/france/

# --- Discoversnoop (Google Discover visibility) ---
# Crée un compte sur https://app.discoversnoop.com/
# Le login est un form POST classique (email + password).
DISCOVERSNOOP_EMAIL=
DISCOVERSNOOP_PASSWORD=
DISCOVERSNOOP_COUNTRY=FR
DISCOVERSNOOP_HOURS=12

# --- Google Search Console (OAuth2) ---
# 1. https://console.cloud.google.com/apis/credentials
# 2. Créer un OAuth Client ID type "Web application"
# 3. Authorized redirect URIs : http://localhost:8765/callback
# 4. Activer l'API "Google Search Console API" sur le projet
# 5. Coller Client ID + Secret ci-dessous
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REDIRECT_URI=http://localhost:8765/callback
# Port du serveur local lancé par `python -m server.cli gsc-connect`
GSC_CALLBACK_PORT=8765

# --- Embeddings (sémantique RAG) ---
# Voyage AI : qualité multilingue, ~$0.06 / 1M tokens. Crée une clé
# sur https://dash.voyageai.com/
# Sans clé, fallback automatique vers TF-IDF stdlib (gratuit, qualité
# moindre mais OK pour démarrer / tester).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# --- Claude (génération de titres dans le style du média) ---
# Crée une clé sur https://console.anthropic.com/settings/keys
# Haiku 4.5 est largement suffisant pour cette tâche, et 5× moins
# cher que Sonnet (~$1/M input, $5/M output).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20250514
